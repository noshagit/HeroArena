<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="#0A0A0F" />
    <SolidColorBrush x:Key="BackgroundMediumBrush" Color="#12121A" />
    <SolidColorBrush x:Key="BackgroundLightBrush" Color="#1A1A26" />

    <SolidColorBrush x:Key="AccentBrush" Color="#8B1A1A" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#A52020" />

    <SolidColorBrush x:Key="GoldBrush" Color="#C8941A" />
    <SolidColorBrush x:Key="GoldHoverBrush" Color="#E0A820" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8E0D0" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9A9080" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#5A5248" />

    <SolidColorBrush x:Key="BorderBrush" Color="#2A2030" />
    <SolidColorBrush x:Key="BorderAccentBrush" Color="#8B1A1A" />

    <SolidColorBrush x:Key="HealthGreenBrush" Color="#2D7A2D" />
    <SolidColorBrush x:Key="HealthRedBrush" Color="#8B1A1A" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#CC3333" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#2D7A2D" />
    <SolidColorBrush x:Key="OverlayBrush" Color="#CC000000" />

    <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0A0A0F" Offset="0.0" />
        <GradientStop Color="#1A0A1A" Offset="0.5" />
        <GradientStop Color="#0F0A0A" Offset="1.0" />
    </LinearGradientBrush>

</ResourceDictionary> 