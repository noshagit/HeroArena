<UserControl x:Class="HeroArena.Views.SpellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:HeroArena.Resources">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="SORTS" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>

            <TextBlock Grid.Row="1" Text="Filtrer par héros :" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>

            <ComboBox Grid.Row="2" ItemsSource="{Binding Heroes}" SelectedItem="{Binding FilterHero, Mode=TwoWay}" DisplayMemberPath="Name" Margin="0,0,0,8" Background="{StaticResource BackgroundLightBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrush}" Padding="8,6"/>

            <Button Grid.Row="3" Content="✖ Effacer le filtre" Command="{Binding ClearFilterCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,12"/>

            <ListBox Grid.Row="4" Style="{StaticResource ModernListBoxStyle}" ItemsSource="{Binding FilteredSpells}" SelectedItem="{Binding SelectedSpell, Mode=TwoWay}" ItemContainerStyle="{StaticResource SpellListItemStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Foreground="{StaticResource AccentBrush}" FontWeight="Bold" VerticalAlignment="Center">
                                <Run Text="{Binding Damage}"/>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Visibility="{Binding HasSelectedSpell, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="{Binding SelectedSpell.Name}" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>

                    <TextBlock Foreground="{StaticResource GoldBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,16">
                        <Run Text="{Binding SelectedSpell.Damage}"/>
                        <Run Text=" dégâts"/>
                    </TextBlock>

                    <TextBlock Text="{Binding SelectedSpell.Description}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,16"/>

                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>

                    <TextBlock Text="Utilisé par :" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>

                    <ItemsControl ItemsSource="{Binding SelectedSpell.HeroSpells}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Hero.Name}" Foreground="{StaticResource AccentBrush}" FontSize="13" Margin="0,2,0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
