<UserControl x:Class="HeroArena.Views.HeroView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:HeroArena.Resources">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="CHOISIR UN HÉROS" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12"/>

            <ListBox Grid.Row="1" Style="{StaticResource ModernListBoxStyle}" ItemsSource="{Binding Heroes}" SelectedItem="{Binding SelectedHero, Mode=TwoWay}" ItemContainerStyle="{StaticResource HeroListItemStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2,0,2">
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Foreground="{StaticResource HealthRedBrush}" FontSize="11">
                                <Run Text="{Binding Health}"/>
                                <Run Text=" HP"/>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Grid.Row="2" Content="Jouer ce héros" Command="{Binding SelectHeroCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,12,0,8" Visibility="{Binding HasSelectedHero, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="{StaticResource GoldBrush}" TextWrapping="Wrap" FontSize="12"/>
        </Grid>

        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Visibility="{Binding HasSelectedHero, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="{Binding SelectedHero.Name}" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>

                    <TextBlock Foreground="{StaticResource HealthRedBrush}" FontSize="14" Margin="0,0,0,16">
                        <Run Text="HP : "/>
                        <Run Text="{Binding SelectedHero.Health}"/>
                    </TextBlock>

                    <TextBlock Text="SORTS" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding SelectedHeroSpells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}" Margin="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" FontSize="13" TextWrapping="Wrap"/>
                                        <TextBlock Foreground="{StaticResource GoldBrush}" FontSize="11" Margin="0,4,0,4">
                                            <Run Text="{Binding Damage}"/>
                                            <Run Text=" dégâts"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="HÉROS SÉLECTIONNÉ" Foreground="{StaticResource GoldBrush}" FontWeight="Bold" FontSize="13" Margin="0,16,0,0" Visibility="{Binding IsHeroSelected, Converter={StaticResource BoolToVisibilityConverter}}"/>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
