<UserControl x:Class="HeroArena.Views.CombatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:HeroArena.Resources">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringToColorBrushConverter x:Key="StringToColorBrushConverter"/>
        <converters:HealthToColorConverter x:Key="HealthToColorConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid Visibility="{Binding HasHero, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Sélectionnez d'abord un héros dans l'onglet Héros" Foreground="{StaticResource TextSecondaryBrush}" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <Button Content="→ Choisir un héros" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Visibility="{Binding HasHero, Converter={StaticResource BoolToVisibilityConverter}}" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{Binding PlayerHero.Name}" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                        <ProgressBar Value="{Binding PlayerHealthPercent, Mode=OneWay}" Maximum="100" Height="14" Margin="0,0,0,4">
                            <ProgressBar.Foreground>
                                <Binding Path="PlayerHealthPercent" Converter="{StaticResource HealthToColorConverter}"/>
                            </ProgressBar.Foreground>
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Background" Value="{StaticResource BackgroundDarkBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>
                        <TextBlock Text="{Binding PlayerHealthText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Column="1" Text="VS" Foreground="{StaticResource AccentBrush}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding EnemyHero.Name}" Style="{StaticResource TitleStyle}" Margin="0,0,0,8"/>
                        <ProgressBar Value="{Binding EnemyHealthPercent, Mode=OneWay}" Maximum="100" Height="14" Margin="0,0,0,4">
                            <ProgressBar.Foreground>
                                <Binding Path="EnemyHealthPercent" Converter="{StaticResource HealthToColorConverter}"/>
                            </ProgressBar.Foreground>
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Background" Value="{StaticResource BackgroundDarkBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>
                        <TextBlock Text="{Binding EnemyHealthText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,0,0,16">
                <TextBlock Text="VOS SORTS — Choisissez une attaque" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,10"/>
                <ItemsControl ItemsSource="{Binding PlayerSpells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" Rows="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource GoldButtonStyle}" Command="{Binding DataContext.UseSpellCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="4" IsEnabled="{Binding DataContext.IsPlayerTurn, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <TextBlock TextWrapping="Wrap" TextAlignment="Center">
                                    <Run Text="{Binding Name}" FontWeight="Bold"/>
                                    <Run Text=" — "/>
                                    <Run Text="{Binding Damage}"/>
                                    <Run Text=" dmg"/>
                                </TextBlock>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" HorizontalAlignment="Right" Margin="0,0,0,8">
                    <Run Text="Score : " Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Run Text="{Binding PlayerScore}" Foreground="{StaticResource GoldBrush}" FontWeight="Bold"/>
                    <Run Text=" pts" Foreground="{StaticResource TextSecondaryBrush}"/>
                </TextBlock>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="LogScrollViewer">
                        <ItemsControl ItemsSource="{Binding CombatLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Message}" Foreground="{Binding Color, Converter={StaticResource StringToColorBrushConverter}}" FontSize="12" Margin="0,1,0,1" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="1" Visibility="{Binding IsCombatOver, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Background="{StaticResource OverlayBrush}" CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CombatStatus}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <Button Content="⚔ NOUVEAU COMBAT" Command="{Binding NewCombatCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" FontSize="14" Padding="24,12"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
