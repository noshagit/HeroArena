<Window x:Class="HeroArena.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Paramètres" Height="400" Width="500" WindowStyle="None" AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterOwner">

    <Border CornerRadius="12" Background="{StaticResource BackgroundMediumBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource BackgroundDarkBrush}" MouseDown="TitleBar_MouseDown">
                <Border CornerRadius="12,12,0,0" Background="Transparent"/>
                <TextBlock Text="PARAMÈTRES BASE DE DONNÉES" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Width="28" Height="28" Style="{StaticResource SecondaryButtonStyle}" Click="CloseButton_Click"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="24">

                <TextBlock Text="URL DE CONNEXION" Style="{StaticResource LabelStyle}" Margin="0,0,0,6"/>

                <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}" MinHeight="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Content="Tester" Command="{Binding TestConnectionCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Sauvegarder" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="Initialiser les données" Command="{Binding SeedDataCommand}" Style="{StaticResource GoldButtonStyle}"/>
                </StackPanel>

                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>
